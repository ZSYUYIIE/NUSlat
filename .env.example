# Core
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
AUTH_SECRET=replace_with_random_secret
AUTH_URL=http://localhost:3000

# Google OAuth (optional but required for Google sign-in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google TTS (optional but recommended for stable Listen audio)
GOOGLE_TTS_API_KEY=your_google_tts_api_key

# Admin token for protected vocabulary imports (/api/vocabulary POST)
VOCAB_ADMIN_TOKEN=replace_with_secure_admin_token

# SMTP (required for actual email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=NUSlat <no-reply@yourdomain.com>
